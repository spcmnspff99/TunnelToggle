# OPNsense Configuration
# The IP address or hostname of your OPNsense firewall
OPNSENSE_IP=192.168.1.1

# The UUID of the firewall alias to manage
# Find this in OPNsense: Firewall → Aliases → Edit alias → Check the URL
ALIAS_UUID=your-alias-uuid-here

# OPNsense API credentials
# Generate these in OPNsense: System → Access → Users → Edit user → API keys
OPNSENSE_KEY=your-api-key-here
OPNSENSE_SECRET=your-api-secret-here

# Flask Application Port
# Default: 5000
FLASK_PORT=5000

# Set the user compatible with the docker host user (gopher)
PGID=1001
PUID=1001